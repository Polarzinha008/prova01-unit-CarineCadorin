{
  "name": "unit-tests-jest",
  "version": "1.0.0",
  "description": "Example to unit tests using Jest",
  "main": "index.js",
  "author": "ugioni",
  "license": "ISC",
  "dependencies": {
    "jest": "^30.0.5"
  },
  "scripts": {
    "clean": "rimraf ./coverage && mkdirp ./coverage",
    "test": "npm run clean && jest",
    "coverage": "npm run clean && jest --coverage"
  },
"jest": {
  "testMatch": ["**/test/**/*.test.js"],
  "coverageReporters": [
    "lcov",
    "text"
  ]
},
  "devDependencies": {
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.3"
  }
}
